# ===========================================
# My-SaaS Environment Variables
# ===========================================
# Copy this file to the appropriate location:
# - Local: apps/api/.env and apps/web/.env.local
# - VPS: /opt/my-saas/{dev,prod}/.env
# ===========================================

# Application
NODE_ENV=development
PORT=3000

# Domain (used for Traefik labels)
DOMAIN=yourdomain.com
GITHUB_USER=your-github-username

# ===========================================
# Traefik (VPS only)
# ===========================================
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com

# Database
DB_USER=saas
DB_NAME=saas_dev
# DB_PASSWORD goes in .secrets file

# Redis
# REDIS_PASSWORD goes in .secrets file

# JWT
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# JWT_SECRET goes in .secrets file
# JWT_REFRESH_SECRET goes in .secrets file

# CORS
CORS_ORIGINS=http://localhost:3001,https://yourdomain.com

# Logging
LOG_LEVEL=info

# ===========================================
# Frontend Environment Variables (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
