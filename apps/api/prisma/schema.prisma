// Prisma Schema for Multi-Tenant SaaS
// Uses schema-per-tenant strategy with shared public schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PUBLIC SCHEMA - Shared across all tenants
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  emailVerified DateTime? @map("email_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret")  // Encrypted TOTP secret
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // User can belong to multiple tenants
  tenantMemberships TenantMember[]
  refreshTokens     RefreshToken[]
  sessions          Session[]

  @@map("users")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  schema    String   @unique // PostgreSQL schema name: tenant_{id}
  plan      Plan     @default(FREE)
  status    TenantStatus @default(ACTIVE)
  settings  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members          TenantMember[]
  supplyCategories SupplyCategory[]
  supplies         Supply[]

  @@map("tenants")
}

model TenantMember {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  role      TenantRole @default(MEMBER)
  joinedAt  DateTime @default(now()) @map("joined_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("tenant_members")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  tokenHash String   @map("token_hash") // Hashed token for secure storage
  familyId  String   @map("family_id")  // Token family for reuse detection
  userId    String   @map("user_id")
  tenantId  String?  @map("tenant_id")
  sessionId String?  @map("session_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  revokedReason String? @map("revoked_reason") // "rotation", "logout", "reuse_detected"

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ============================================
// Session Management - Device tracking
// ============================================

model Session {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  tenantId     String?   @map("tenant_id")
  deviceName   String?   @map("device_name")   // "Chrome on MacOS"
  deviceType   String?   @map("device_type")   // "desktop", "mobile", "tablet"
  browser      String?
  os           String?
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  lastActiveAt DateTime  @default(now()) @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([lastActiveAt])
  @@map("sessions")
}

// ============================================
// API Keys - For programmatic access
// ============================================

model ApiKey {
  id          String    @id @default(cuid())
  name        String                          // "Production API Key"
  keyHash     String    @unique @map("key_hash") // Hashed API key
  keyPrefix   String    @map("key_prefix")    // First 8 chars for identification
  tenantId    String    @map("tenant_id")
  userId      String    @map("user_id")       // Who created it
  scopes      String[]  @default([])          // ["read:supplies", "write:supplies"]
  rateLimit   Int       @default(1000) @map("rate_limit") // Requests per hour
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  usageCount  Int       @default(0) @map("usage_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// ============================================
// Idempotency Keys - Safe retries
// ============================================

model IdempotencyKey {
  id         String   @id @default(cuid())
  key        String   @unique
  tenantId   String?  @map("tenant_id")
  userId     String?  @map("user_id")
  endpoint   String
  method     String
  statusCode Int?     @map("status_code")
  response   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ============================================
// Webhook Deliveries - Outgoing webhooks
// ============================================

model WebhookEndpoint {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  url        String
  secret     String                          // HMAC secret (encrypted)
  events     String[] @default([])           // ["supply.created", "supply.deleted"]
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  endpointId   String   @map("endpoint_id")
  event        String
  payload      Json
  signature    String                        // HMAC-SHA256 signature
  timestamp    DateTime @default(now())
  statusCode   Int?     @map("status_code")
  response     String?
  attempts     Int      @default(0)
  nextRetryAt  DateTime? @map("next_retry_at")
  deliveredAt  DateTime? @map("delivered_at")
  failedAt     DateTime? @map("failed_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([timestamp])
  @@map("webhook_deliveries")
}

// ============================================
// LGPD Compliance
// ============================================

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  tenantId    String?  @map("tenant_id")
  consentType String   @map("consent_type")  // "terms", "privacy", "marketing"
  version     String                          // Version of the document
  granted     Boolean  @default(true)
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  @@index([userId])
  @@index([consentType])
  @@map("consent_records")
}

model DataDeletionRequest {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  tenantId    String?  @map("tenant_id")
  requestedAt DateTime @default(now()) @map("requested_at")
  scheduledAt DateTime @map("scheduled_at")   // When deletion will occur
  completedAt DateTime? @map("completed_at")
  status      DeletionStatus @default(PENDING)
  dataTypes   String[] @default([])           // ["profile", "activity", "all"]

  @@index([userId])
  @@index([status])
  @@map("data_deletion_requests")
}

model DataRetentionPolicy {
  id            String   @id @default(cuid())
  tenantId      String?  @map("tenant_id")
  entityType    String   @map("entity_type")  // "audit_logs", "sessions", etc
  retentionDays Int      @map("retention_days")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType])
  @@map("data_retention_policies")
}

enum DeletionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ============================================
// Audit Log - Track sensitive operations
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  tenantId  String?  @map("tenant_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// Enums
// ============================================

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ============================================
// TENANT-SCOPED MODELS - Business entities
// ============================================

model SupplyCategory {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  color       String?   // Hex color for UI badges
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplies    Supply[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("supply_categories")
}

model Supply {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  categoryId  String          @map("category_id")
  name        String
  description String?
  unit        String          // kg, L, un, etc.
  minStock    Float?          @map("min_stock")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    SupplyCategory  @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([categoryId])
  @@map("supplies")
}
