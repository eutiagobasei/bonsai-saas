# Bonsai-Wiki Configuration
# Claude Code knowledge management

[wiki]
path = wiki
index = wiki/index.md
log = wiki/log.md

[raw]
path = raw
meetings = raw/meetings
decisions = raw/decisions

[patterns]
concepts = wiki/conceitos
decisions = wiki/decisoes
architecture = wiki/arquitetura

[behavior]
auto_update_log = true
max_log_entries = 100
