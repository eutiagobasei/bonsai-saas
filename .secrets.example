# ===========================================
# My-SaaS Secrets
# ===========================================
# SECURITY: This file contains sensitive data!
# - NEVER commit to version control
# - Set permissions: chmod 600 .secrets
# - Place in /opt/my-saas/{dev,prod}/.secrets on VPS
# ===========================================

# Database
DB_PASSWORD=your-secure-database-password

# Redis
REDIS_PASSWORD=your-secure-redis-password

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-replace-this-with-a-real-one
JWT_REFRESH_SECRET=your-super-secret-refresh-key-replace-this-too

# Optional: External Services
# STRIPE_SECRET_KEY=sk_test_xxxx
# SENDGRID_API_KEY=SG.xxxx
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=xxxx
